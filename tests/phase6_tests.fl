  if test_t29_shutdown() { passed = passed + 1; } else { failed = failed + 1; }
  if test_t30_numa_allocation() { passed = passed + 1; } else { failed = failed + 1; }
  if test_t31_numa_imbalance() { passed = passed + 1; } else { failed = failed + 1; }
  if test_t32_cache_layout() { passed = passed + 1; } else { failed = failed + 1; }
  if test_t33_memory_pool() { passed = passed + 1; } else { failed = failed + 1; }
  if test_t34_pool_allocation() { passed = passed + 1; } else { failed = failed + 1; }
  if test_t35_pool_freeing() { passed = passed + 1; } else { failed = failed + 1; }
  if test_t36_compression() { passed = passed + 1; } else { failed = failed + 1; }
