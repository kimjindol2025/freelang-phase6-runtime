// MAIN TEST RUNNER
// ============================================================================

fn run_all_tests() -> bool {
  let mut passed = 0;
  let mut failed = 0;

  // Test groups
  if test_t1_hotpath_detection() { passed = passed + 1; } else { failed = failed + 1; }
  if test_t2_baseline_compilation() { passed = passed + 1; } else { failed = failed + 1; }
  if test_t3_code_execution() { passed = passed + 1; } else { failed = failed + 1; }
